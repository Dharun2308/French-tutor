# Copy this file to .env.local and fill in real values.

# --- Turso ---
# Create a database at https://turso.tech, then run:
#   turso db show <your-db> --url
#   turso db tokens create <your-db>
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# --- OpenAI ---
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
# Optional overrides. Default is gpt-5-mini.
OPENAI_MODEL="gpt-5-mini"
# Optional override for text-to-speech. Default is gpt-4o-mini-tts.
# Only used when TTS mode is set to "openai" in Settings.
OPENAI_TTS_MODEL="gpt-4o-mini-tts"

# --- Seed endpoint protection ---
# Any string. Only needed if you hit POST /api/seed in production.
SEED_TOKEN="choose-a-long-random-string"
